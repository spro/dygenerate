{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "types": ["vite/client"],
        "lib": ["ES2023", "DOM", "DOM.Iterable"]
    },
    "include": ["src/client/**/*"]
}
